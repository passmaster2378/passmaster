NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# 32-byte secret key for vault encryption (base64 recommended).
# Generate:
# - mac/linux: openssl rand -base64 32
# - windows (powershell): [Convert]::ToBase64String((1..32 | ForEach-Object {Get-Random -Minimum 0 -Maximum 256}))
VAULT_ENCRYPTION_KEY="BASE64_32_BYTES"

# Admin allowlist (comma-separated emails). If the logged-in user's email matches,
# they will be auto-marked as admin and redirected to /admin/orders.
ADMIN_EMAILS="admin@example.com"

# Optional: helps OAuth redirectTo stay correct in some dev/prod setups
# Example (production):
# NEXT_PUBLIC_SITE_URL="https://passmaster-liard.vercel.app"
# Example (local):
# NEXT_PUBLIC_SITE_URL="http://localhost:3000"
